# ============================================================================
# CoinGecko — token pricing
# Server-side key (proxied; never exposed to the browser). Get one at:
# https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# Turn pricing ON in the hosted build. Set to "true" alongside COINGECKO_API_KEY
# so hosted users see USD prices. (Local mode always has pricing on.)
NEXT_PUBLIC_PRICING_ENABLED=

# 0x Standard Swap API Base URL
NEXT_PUBLIC_0X_API_URL=https://api.0x.org

# ============================================================================
# 0x — token swaps
# Server-side key (proxied; preferred — NOT exposed in the client bundle).
# Get one at: https://0x.org   (uses the standard swap API; users pay their own gas)
ZEROX_API_KEY=
# Legacy/local fallback (exposed to the client — avoid for public deployments):
NEXT_PUBLIC_0X_API_KEY=

# Alchemy NFT API Configuration
# Optional: enables automatic NFT gallery discovery (ERC-721 & ERC-1155).
# One key works across all supported chains. Without it, users can still add
# NFTs manually by contract address (read on-chain via their RPC).
# Get your API key at: https://www.alchemy.com
# Note: server-side only (no NEXT_PUBLIC_ prefix) so the key is never exposed.
ALCHEMY_API_KEY=

# WalletConnect (Reown) Project ID
# Enables connecting OpenBurner to dApps (scan/paste a WalletConnect URI).
# Free project id from https://cloud.reown.com — safe to expose client-side.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ============================================================================
# Hosted abuse protection (optional)
# Restrict the proxy routes to your own domain(s) — comma-separated. Leave unset
# to allow any origin. Recommended for a public deployment using shared keys.
ALLOWED_ORIGINS=

